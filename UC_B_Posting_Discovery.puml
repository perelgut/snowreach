@startuml UC-04
' SnowReach - Use Case Diagrams - Group B: Job Posting, Discovery, and Acceptance
' UC-04, UC-05, UC-06, UC-07, UC-08, UC-09, UC-10

skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333

title UC-04 - Post a Snow Clearing Job

start

:Requester taps "Post a Job";

:Property address pre-populated from profile\nRequester may enter a different address\n(e.g., elderly parent's home) -\nvalidated against launch zone.;

:Select scope of work\n(checkboxes: driveway / front walk /\nside path / steps / corner sidewalk);

:Enter timing note (free text)\n"ASAP", "Before 8am", etc.\nv1 only: this is the only timing\nmechanism. No structured scheduling.\nSee Gap G-01.;

:Optionally upload up to 5 scoping photos\nwith short description (max 500 chars);

if (Photo upload fails?) then (yes)
  :Non-blocking warning shown\nJob proceeds without photos;
else (success or no photos)
endif

if (Address outside active launch zone?) then (yes)
  :Request rejected\nRedirected to register-interest page;
  stop
else (in active zone)
endif

if (Workers available in range?) then (yes)
  :System displays applicable price ranges\nfrom Workers in area;
  :Requester reviews payment model explanation\nand confirms understanding;
  :Job draft created;
  :Proceed to UC-05 - Browse Workers;
  stop
else (none available)
  :No Workers message shown\nOptions: wait / expand to buffer / register interest;
  stop
endif

@enduml

@startuml UC-05
' SnowReach - Use Case Diagrams - Group B: Job Posting, Discovery, and Acceptance

skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333

title UC-05 - Browse and Filter Available Workers

start

:System displays Worker list\nSorted: (1) rating desc,\n(2) acceptance rate desc (>=5 jobs),\n(3) distance asc.\nEach card shows: name, photo, rating,\ndistance, price, equipment type,\ndispatcher badge, buffer badge.;

:Requester browses list;

repeat

  if (Requester applies filter?) then (yes)
    :Filter by: equipment type /\nmax price / personal vs. dispatcher;
  else (no filter)
  endif

  if (Requester taps a Worker card?) then (yes)
    :View full Worker profile - UC-06;
    if (Taps "Add to Request"?) then (yes)
      :Worker added to selection tray;
    else (taps Back)
      :Return to Worker list;
    endif
  else (no tap)
  endif

  if (Selection tray has 3 Workers?) then (yes)
    :Maximum reached - no more can be added;
  else (fewer than 3)
  endif

repeat while (Requester taps "Send Request"?) is (not yet)

:1 to 3 Workers selected;
:Proceed to UC-07 - Send Job Request;

stop

@enduml

@startuml UC-06
' SnowReach - Use Case Diagrams - Group B: Job Posting, Discovery, and Acceptance

skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333

title UC-06 - View Worker Profile

start

:Requester taps a Worker card from the list;

:Full Worker profile displayed\nShows: name, photo, equipment,\nservice radius, pricing tiers,\naggregate rating (stars + count),\nall ratings and review text,\ncompleted job count, dispatcher badge,\ntrust badges (onboarding Phase 2+;\nbackground check/insured Phase 3+),\nbuffer opt-in status.;

if (Worker has zero completed jobs?) then (yes)
  :"New Worker" badge shown\nNo rating displayed;
else (has completed jobs)
endif

if (Requester decision?) then (Add to Request)
  :Worker added to selection tray;
  :Return to UC-05;
  stop
else (Back)
  :Return to Worker list - no selection made;
  stop
endif

@enduml

@startuml UC-07
' SnowReach - Use Case Diagrams - Group B: Job Posting, Discovery, and Acceptance

skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333

title UC-07 - Send Job Request to Selected Workers

start

:Requester taps "Send Request";

:System checks availability of\nall selected Workers\nA Worker may have gone Unavailable\nbetween selection and dispatch.\nThat Worker is skipped.;

if (No Workers still Available?) then (yes)
  :Requester returned to Worker list;
  stop
else (Workers available)
endif

:Notifications dispatched simultaneously\nto all available selected Workers\nEach notification contains:\njob scope, Requester aggregate rating,\napprox. distance, applicable price,\nand timing note.;

:Job status -> Requested\n10-minute acceptance window begins\n(countdown visible to Requester);

if (Requester cancels while Requested?) then (yes)
  :Job -> Cancelled\nAll selected Workers notified;
  stop
else (no)
  :Awaiting Worker responses - UC-09;
  stop
endif

@enduml

@startuml UC-08
' SnowReach - Use Case Diagrams - Group B: Job Posting, Discovery, and Acceptance

skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333

title UC-08 - Complete Escrow Deposit (Phase 2 only)

start

:Precondition: A Worker has accepted (UC-09).\nJob is in Pending Deposit state.\n30-minute deposit window is running.;

:Requester notified:\n"[Worker] has accepted your job.\nPlease deposit $[amount] to confirm.";

:Summary screen shown:\nscope, Worker name, total price,\n15% commission disclosure,\n$10 cancellation fee warning;

:Requester checks property damage\nacknowledgement checkbox (mandatory);

:Requester taps "Pay"\nand authorises via saved Stripe method;

if (Requester cancels during window?) then (yes)
  :Job -> Cancelled\nNo funds involved\nWorker notified;
  stop
else (no)
endif

if (30-minute window expired?) then (yes)
  :Auto-cancel fires\nJob -> Cancelled\nWorker -> Available\nWorker notified;
  stop
else (still active)
endif

if (Stripe charge succeeds?) then (yes)
  :Job status -> Confirmed\nFunds held in escrow\nExact addresses disclosed to both parties\nMessaging thread opens;
  :Proceed to UC-11 - Begin Work;
  stop
else (charge fails)
  :Failure reason shown\n(declined / expired / insufficient funds /\nfraud prevention block)\nRequester retries - timer continues\nIf window expires during retries: auto-cancel applies.;
  stop
endif

@enduml

@startuml UC-09
' SnowReach - Use Case Diagrams - Group B: Job Posting, Discovery, and Acceptance

skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333

title UC-09 - Accept or Reject a Job Request

start

:Worker receives job request notification;

if (Job already filled by another Worker?) then (yes)
  :"This job has been filled" shown\nNon-response NOT counted;
  stop
else (still open)
endif

if (10-minute window expired?) then (yes)
  :Non-response recorded on Worker account;
  if (3 consecutive non-responses?) then (yes)
    :Worker status -> Unavailable\n(must manually re-activate);
  else (fewer than 3)
  endif
  :Requester returned to Worker list;
  stop
else (still active)
endif

:Worker reviews notification\nContains: scope, Requester aggregate\nrating, approx. distance, price,\ntiming note, scoping photos.;

if (Buffer zone job?) then (yes)
  :Banner: "Extended Range - X.X km\nOutside your usual service radius";
  if (Worker declines or ignores?) then (yes)
    :Decline logged - no penalty;
    stop
  else (taps "Accept Anyway")
  endif
else (standard range)
endif

if (Worker taps Accept?) then (yes)
  :Phase 1: Job -> Confirmed - addresses shared\nPhase 2: Job -> Pending Deposit - UC-08\nWorker -> Busy\nOther selected Workers released\n(their non-responses NOT counted);
  stop
else (Worker taps Decline)
  :Decline logged for analytics\nNo penalty\nJob stays Requested for remaining Workers;
  stop
endif

@enduml

@startuml UC-10
' SnowReach - Use Case Diagrams - Group B: Job Posting, Discovery, and Acceptance

skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333

title UC-10 - Negotiate Fee and Timing

start

:v1: No negotiation mechanism.\nWorker sees Requester timing note (read-only).\nRequester sees Worker set prices (read-only).\nOnly recourse: decline or select different party.\nTiming/scheduling: no mechanism in any version.\nSee Gap G-01.;

:-- v2 counter-offer flow --;

:Worker finds current price insufficient\nfor scope or distance;

:Worker submits counter-offer\n(proposed price + optional note);

:Requester notified of counter-offer;

if (Requester decision?) then (Accept)
  :Job proceeds at counter-offer price;
  stop
elseif (Re-counter - rounds remain?) then (yes)
  :Requester submits new counter\n(max 3 rounds total);
  :Worker notified;
  if (Worker accepts Requester counter?) then (yes)
    :Job proceeds at agreed price;
    stop
  else (declines)
    :Worker may accept original price\nor request expires;
    stop
  endif
else (Reject or round limit reached)
  :Worker may accept original price\nor request expires;
  stop
endif

@enduml
