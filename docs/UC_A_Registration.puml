@startuml UC-01
skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333
title UC-01 - Register as Requester
start
:User selects "Sign up as Requester"\nand chooses auth method\n(email/password, Google, or Apple);
:Enter full name, property address, date of birth;
:System geocodes property address;
if (Email already registered?) then (yes)
  :Prompt to log in or reset password;
  stop
else (no)
endif
if (Geocoding failed after all fallbacks?) then (yes)
  :Error shown - user must re-enter address;
  stop
else (geocoded ok)
endif
if (Address outside all active launch zones?) then (yes)
  :Account created - Inactive\n(not matched to Workers until zone launches);
else (in active zone)
endif
if (Age < 18?) then (yes)
  :Registration rejected - age under 18;
  stop
else (18 or over)
endif
:User reads and actively accepts\nTerms of Service and Privacy Policy;
note right
  Acceptance timestamped and
  stored immutably in account record.
end note
:User adds payment method\n(credit/debit card via Stripe);
if (Card validated by Stripe?) then (yes)
  :Account activated - Full access;
else (validation fails)
  :Account created - No payment method\n(cannot post jobs until card is added);
endif
:Requester dashboard shown;
stop
@enduml

@startuml UC-02
skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333
title UC-02 - Register as Personal Worker
start
:User selects "Sign up as a Worker" - Personal;
:Enter full name and base address;
note right
  Base address is private -
  never shown to Requesters.
end note
:Declare equipment type\n(snowblower / shovel / truck plow / other);
:Set distance/price tiers\n(1-3 tiers: distance boundary + price per tier)\nMinimum $20 CAD per tier;
:Set maximum service radius (1-25 km);
:Optionally enable 10% radius buffer;
note right
  When on, Worker may receive offers up to
  10% beyond their max radius.
  Each offer is labelled with actual distance.
end note
:Connect Stripe account for payment receiving;
if (Stripe Connect not linked?) then (yes)
  :Flagged - cannot accept jobs\nuntil Stripe is connected;
else (linked)
endif
if (Age < 18?) then (yes)
  :Registration rejected - age under 18;
  stop
else (18 or over)
endif
:Accept Terms of Service,\nAge Verification acknowledgement,\nand Privacy Policy;
note right
  Onboarding module: deferred to Phase 2.
  Insurance declaration: deferred to Phase 3.
end note
:Verify phone number;
if (Phone verified?) then (yes)
  :Account activated - Full access\nStatus: Available;
else (skipped)
  :Account activated - Phone pending\nFirst job blocked until phone is verified;
endif
:Worker dashboard shown;
stop
@enduml

@startuml UC-03
skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333
title UC-03 - Register as Dispatcher
start
:User selects "Sign up as a Worker"\nthen "I assign work to crew members";
:Enter crew member names (free text list)\nand approximate crew size;
if (Crew size entered as zero?) then (yes)
  :Warning: "Please add at least one crew member";
  :User corrects crew details;
else (one or more crew members)
endif
:Acknowledge on-site disclosure obligation;
note right
  For every job, Dispatcher must disclose
  who will perform work at the Requester's
  property before work begins (FR-LIAB-03/04).
  Acknowledgement is timestamped.
end note
:Set distance/price tiers,\nmax service radius, buffer opt-in\n(same steps as UC-02);
:Complete remaining UC-02 steps\n(Stripe Connect, age check,\nterms acceptance, phone verification);
:Account activated\nDispatcher badge stored on public profile;
note right
  Badge is visible to Requesters before they
  select this Worker, giving advance notice
  that work may be performed by a crew member.
end note
:Worker dashboard shown;
stop
@enduml
