@startuml UC-20
' SnowReach - Use Case Diagrams - Group F: Payment Exceptions
' UC-20, UC-21, UC-22a, UC-22b, UC-23, UC-24, UC-25

skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333

title UC-20 - Timer-Based Auto-Operation Failure

start

:Three timers drive automatic transitions:\n- Auto-release: Complete -> Released (4hr)\n- Auto-cancel: Pending Deposit -> Cancelled (30min)\n- Auto-refund: Incomplete -> Refunded (24hr)\nAll timers use durable persistent scheduling.;

if (Platform restarted while timer was pending?) then (yes)
  :Durable scheduler reads all pending\ntimers from database on startup;
  if (Timer already past its fire time?) then (yes)
    :Timer executed immediately on recovery;
  else (not yet due)
    :Timer resumes from remaining duration;
    stop
  endif
else (Normal - timer fires at scheduled time)
endif

:System initiates Stripe operation\n(release / cancel / refund);

if (Stripe operation succeeds?) then (yes)
  :Job transitions to terminal state\n(Released / Cancelled / Refunded);
  stop
else (Stripe error - 5xx / timeout / network)
  :Retry with exponential backoff\n(up to 3 attempts);
  if (Any retry succeeds?) then (yes)
    :Job transitions to terminal state;
    stop
  else (all 3 retries fail)
    :Job remains in current state\nAdmin-only label: "Payment Processing Delayed"\nAdmin alerted by email\nException record created in Admin queue;
    :Admin manually triggers operation\nor extends window as warranted;
    :Job transitions to terminal state;
    stop
  endif
endif

@enduml

@startuml UC-21
' SnowReach - Use Case Diagrams - Group F: Payment Exceptions

skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333

title UC-21 - Stripe API Outage

start

:Platform detects 3+ consecutive Stripe API\nerrors within a 5-minute window;

:Platform enters Payment-Suspended mode\nJob state effects during suspension:\n- Requested / Confirmed / In Progress: unaffected\n- Pending Deposit: 30-min window paused\n- Complete: auto-release timer paused\n- Incomplete: auto-refund timer paused;

:Admin alerted immediately\nAffected users notified of delay;

:All pending Stripe operations queued internally\nAll active timers frozen at remaining duration;

repeat
  :Monitor Stripe API;
repeat while (Stripe test call succeeds?) is (not yet)

:Recovery detected;

:Exit Payment-Suspended mode\nQueued operations executed oldest-first\n(idempotency keys applied)\nTimers resume from remaining duration;

:Admin receives recovery notification\nAffected users notified:\n"Payment processing has resumed";

stop

@enduml

@startuml UC-22a
' SnowReach - Use Case Diagrams - Group F: Payment Exceptions

skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333

title UC-22a - Escrow Deposit Failure (Phase 2)

start

:Precondition (Phase 2):\nWorker accepted; job in Pending Deposit.\n30-minute deposit window is running.;

:Requester authorises payment\nvia saved Stripe payment method;

if (Stripe charge succeeds?) then (yes)
  :Job -> Confirmed\nEscrow held;
  stop
else (charge fails)
  :Failure reason displayed\n(declined / expired / insufficient funds /\nfraud prevention block);
  :Requester retries with same or different card;
  if (30-minute window still active?) then (yes)
    if (Retry succeeds?) then (yes)
      :Job -> Confirmed - Escrow held;
      stop
    else (fails again)
      :Requester may continue retrying\nuntil window expires;
      stop
    endif
  else (window expired during retries)
    :Auto-cancel fires\nJob -> Cancelled\nWorker -> Available - Worker notified;
    stop
  endif
endif

@enduml

@startuml UC-22b
' SnowReach - Use Case Diagrams - Group F: Payment Exceptions

skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333

title UC-22b - Post-Completion Charge Failure (Phase 1)

start

:Phase 1 risk: No pre-job escrow.\nWorker has already completed work before\npayment is secured. A permanent charge\nfailure means the Worker may not be paid.\nThis is the primary motivation for Phase 2.;

:Worker marks job Complete\nPlatform immediately charges\nRequester's saved payment method;

if (Charge succeeds?) then (yes)
  :Job -> Released\nWorker receives 85%;
  stop
else (charge fails)
  :Retry up to 3 times over 24-hour window;
  if (Any retry succeeds?) then (yes)
    :Job -> Released\nWorker receives 85%;
    stop
  else (all retries fail)
    :Payment exception created in Admin queue\nWorker notified of delay\nRequester notified to update payment method\nAdmin alerted;
    if (Requester updates card - charge succeeds?) then (yes)
      :Job -> Released\nWorker receives 85%;
      stop
    else (unresolvable)
      :Admin determines outcome\n(bad-debt process);
      stop
    endif
  endif
endif

@enduml

@startuml UC-23
' SnowReach - Use Case Diagrams - Group F: Payment Exceptions

skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333

title UC-23 - Worker Payout Failure

start

:Precondition: Disbursement authorised\n(job is Released or Settled).;

:Platform initiates Stripe Connect\ntransfer to Worker's bank account;

if (Transfer succeeds?) then (yes)
  :Funds delivered to Worker;
  stop
else (payout fails)
  :Exception record created in Admin queue\nAdmin alerted\nWorker notified: "Payout could not be delivered\nPlease check your Stripe account"\nCauses:\n- Stripe Connect not fully set up\n- Bank account closed or rejected\n- Stripe account suspended\n- Bank hard-return after initial acceptance;
  if (Worker responds and updates\nStripe Connect within 90 days?) then (yes)
    :Worker or Admin retries payout;
    if (Retry succeeds?) then (yes)
      :Funds delivered\nException closed;
      stop
    else (fails again)
      :Further troubleshooting required;
      stop
    endif
  else (90 days - no response)
    :Funds held in Admin-controlled state\nWorker account may be suspended\nEscalated to App Owner legal/compliance;
    stop
  endif
endif

@enduml

@startuml UC-24
' SnowReach - Use Case Diagrams - Group F: Payment Exceptions

skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333

title UC-24 - Duplicate or Erroneous Charge

start

:Client-side guard: Pay button disabled after first tap.\nServer-side guard: Every charge uses a unique idempotency key.;

:Platform submits Stripe charge\n(deposit / completion charge / tip);

if (Network timeout before\nStripe response received?) then (yes)
  :Platform retries with the SAME idempotency key;
  :Stripe recognises key - returns result of\noriginal charge - no new charge created;
  :Single charge - no duplicate - no user impact;
  stop
else (normal first submission)
endif

if (Platform bug: two charges submitted\nwith different keys for same job?) then (yes)
  :Both charges succeed at Stripe\n(two charges on Requester's card);
  :Platform detects duplicate:\nsame Requester + job ID + amount\nwithin 5-minute window;
  :Stripe refund initiated immediately\nfor the duplicate charge;
  :Requester notified:\n"Duplicate charge automatically refunded";
  :Admin alerted - both charge IDs logged\nDev team notified via incident log;
  stop
else (single charge - no issue)
  :Charge succeeded normally;
  stop
endif

@enduml

@startuml UC-25
' SnowReach - Use Case Diagrams - Group F: Payment Exceptions

skinparam ActivityBackgroundColor #f5f5f5
skinparam ActivityBorderColor #555555
skinparam ActivityDiamondBackgroundColor #fff3cd
skinparam ActivityDiamondBorderColor #856404
skinparam NoteBackgroundColor #e8f4f8
skinparam NoteBorderColor #2980b9
skinparam ArrowColor #333333

title UC-25 - Refund Processing Failure

start

:Refund authorised from:\n- Dispute ruling\n- Cannot Complete auto-refund\n- Job cancellation;

:Platform submits refund to Stripe;

if (Refund succeeds?) then (yes)
  :Refund delivered to Requester;
  stop
else (fails)
  :Retry up to 3 times with exponential backoff;
  if (Any retry succeeds?) then (yes)
    :Refund delivered;
    stop
  else (all retries fail)
    :Exception created in Admin queue\nAdmin alerted\nRequester notified:\n"We will contact you within 2 business days";
    if (Stripe reports "already fully refunded"?) then (yes)
      :Exception closed\nRequester notified: refund is complete;
      stop
    else (genuinely failed - proceed to resolution)
      :Admin contacts Requester to arrange resolution;
    endif
    if (Requester account is reachable?) then (yes)
      if (Admin resolution path?) then (Platform credit)
        :Refund credited to Requester's\nSnowReach account\nApplied to next job deposit automatically\nException closed;
        stop
      else (Manual bank transfer)
        :App Owner initiates e-transfer\nRequester provides banking details\nvia secure channel\nException closed;
        stop
      endif
    else (account closed - no contact possible)
      :Funds retained in unclaimed state\nOntario Unclaimed Intangible Property Act applies;
      stop
    endif
  endif
endif

@enduml
