// ============================================================
// YoSnowMow — Firestore Collection Structure
// Full security rules are implemented in P1-21.
// This file documents all 13 collection paths for reference.
//
// PRIMARY DATABASE (snowreach-dev / snowreach-prod):
//   /users/{uid}                        — account profile (both roles)
//   /workers/{uid}                      — worker-specific data (equipment, service area, ratings)
//   /jobs/{jobId}                       — job document (full lifecycle, all financial fields in cents)
//   /jobRequests/{id}                   — pending dispatch record (one per REQUESTED job)
//   /ratings/{id}                       — mutual ratings after job completion
//   /disputes/{disputeId}               — dispute record with statements and evidence refs
//   /notifications/{uid}/feed/{notifId} — per-user notification feed (subcollection)
//   /geocache/{hash}                    — cached geocoding results keyed by postal-code hash
//   /analytics/daily/{date}             — daily roll-up aggregates (date = YYYY-MM-DD)
//   /analytics/summary/current          — live summary document for admin dashboard
//   /fraudFlags/{flagId}                — automated fraud detection flags
//   /adminReviewQueue/{id}              — items requiring manual admin review
//
// AUDIT DATABASE (snowreach-audit — separate Firebase project, append-only):
//   /auditLog/{entryId}                 — SHA-256 hash-chained audit entries
//
// Deploy commands:
//   Dev:  firebase use default && firebase deploy --only firestore:rules
//   Prod: firebase use prod    && firebase deploy --only firestore:rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DENY ALL — security rules implemented in P1-21
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
